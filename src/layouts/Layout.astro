---
import '../styles/global.css';

const { title = "Mes Brouillons", description = "Mini-essais scientifiques et simulations" } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo_mesbrouillons.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">Mes Brouillons</a>
        <nav>
          <a href="/a-propos">À propos</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>Mes Brouillons — Apprendre en public.</p>
        <p><a href="https://mesbrouillons.substack.com" target="_blank" rel="noopener">Newsletter</a></p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  .site-header {
    border-bottom: 1px solid var(--color-grey-light);
    padding: 1.5rem 0;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 960px;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    color: var(--color-black);
    border-bottom: none;
    letter-spacing: 0.02em;
  }

  .logo:hover {
    color: var(--color-red);
  }

  nav {
    display: flex;
    gap: 2rem;
  }

  nav a {
    font-size: 0.95rem;
    border-bottom: none;
    color: var(--color-grey-dark);
  }

  nav a:hover {
    color: var(--color-red);
  }

  main {
    min-height: 60vh;
    padding: 3rem 0 4rem;
  }

  .site-footer {
    border-top: 1px solid var(--color-grey-light);
    padding: 2rem 0;
    text-align: center;
  }

  .site-footer p {
    font-size: 0.85rem;
    color: var(--color-grey-mid);
    margin-bottom: 0.25rem;
  }
</style>