---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mes Brouillons">

  <div class="container">

    <div class="intro">
      <h1 class="intro__title">Mes Brouillons</h1>
      <p class="intro__tag">Apprendre en public.</p>
      <p class="intro__sub">
        J'essaie de comprendre comment fonctionne le vivant. Mécanisme précis ou
        principe général — chaque brouillon suit un concept fondamental que je tentes d'éclairer.
      </p>
    </div>

    <div class="catalog">

      <section class="category">
        <h2 class="category__label">Évolution</h2>
        <ul class="article-list">
          <li class="article-list__item">
            <a href="/simulations/le-pari-de-la-sexualite" class="article-link">
              <div class="article-link__body">
                <span class="article-link__title">Le pari de la sexualité</span>
                <span class="article-link__desc">
                  Pourquoi la reproduction sexuée persiste malgré son coût démographique.
                </span>
              </div>
              <span class="article-link__arrow">→</span>
            </a>
          </li>
        </ul>
      </section>

      <section class="category">
        <h2 class="category__label">Collectif</h2>
      </section>

      <section class="category">
        <h2 class="category__label">Écologie</h2>
      </section>

      <section class="category">
        <h2 class="category__label">Information</h2>
      </section>

    </div>

  </div>

</Layout>

<style>
  /* ── Intro ── */
  .intro {
    padding: 5rem 0;
    border-bottom: 1px solid var(--color-grey-light);
    margin-bottom: 4rem;
    text-align: center;
  }

  .intro__title {
    font-family: var(--font-serif);
    font-size: 2.8rem;
    font-weight: 400;
    color: var(--color-black);
    margin-bottom: 0.5rem;
  }

  .intro__tag {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-grey-mid);
    margin-bottom: 1.75rem;
  }

  .intro__sub {
    font-size: 0.95rem;
    color: var(--color-grey-dark);
    max-width: 400px;
    line-height: 1.75;
    margin: 0 auto;
  }

  /* ── Catalogue ── */
  .catalog {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding-bottom: 6rem;
  }

  .category__label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-grey-mid);
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-grey-light);
    margin-bottom: 0;
  }

  /* ── Liste d'articles ── */
  .article-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    margin-top: 0;
  }

  .article-list__item {
    border-bottom: 1px solid var(--color-grey-light);
    padding: 1.25rem 0;
  }

  /* ── Lien article ── */
  .article-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    border-bottom: none;
    color: var(--color-black);
  }

  .article-link__body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .article-link__title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-black);
    transition: color 0.15s;
  }

  .article-link:hover .article-link__title {
    color: var(--color-red);
  }

  .article-link__desc {
    font-size: 0.85rem;
    color: var(--color-grey-mid);
    line-height: 1.5;
  }

  .article-link__arrow {
    font-size: 1rem;
    color: var(--color-grey-mid);
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .article-link:hover .article-link__arrow {
    color: var(--color-red);
  }
</style>
